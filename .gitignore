# 虚拟环境
.venv/

# 环境变量（含 API Key，不提交）
.env

# 输出目录（保留文件夹结构，不提交内部内容）
images/*
!images/.gitkeep
ppt/*
!ppt/.gitkeep
logs/*
!logs/.gitkeep

# 参考图（个人隐私图片，保留文件夹结构，不提交内部内容）
reference_images/*
!reference_images/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo

# IDE
.vscode/
.idea/

# 工具产物
.playwright-mcp/
.serena/

# uv
uv.lock
